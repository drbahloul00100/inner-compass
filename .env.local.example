# Local environment variables for Inner Compass.
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.

# --- Supabase (Phase 2+) ---
# Browser-safe; also set on Netlify.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Supabase service role (Phase 4) ---
# SERVER-ONLY. Used by netlify/functions/generate-report-background.ts to
# write report_text back into scoring_results bypassing RLS. NEVER expose
# to the client. Set on Netlify via:
#   netlify env:set SUPABASE_SERVICE_ROLE_KEY <your-service-role-key>
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic / Claude (Phase 4) ---
# Server-only. Used by netlify/functions/generate-report-background.ts.
# NEVER expose to the client.
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Future phases ---
# Phase 6: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
